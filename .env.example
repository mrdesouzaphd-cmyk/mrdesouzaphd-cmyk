# Content-to-Ebook Agent — Environment Variables
# Copy this to .env and fill in your values

# Google Cloud
EBOOK_AGENT_GCP_PROJECT_ID=your-project-id
EBOOK_AGENT_GCP_REGION=us-central1
EBOOK_AGENT_GCS_RAW_BUCKET=your-project-id-ebook-raw-uploads
EBOOK_AGENT_GCS_PROCESSED_BUCKET=your-project-id-ebook-processed
EBOOK_AGENT_GCS_EBOOK_BUCKET=your-project-id-ebook-final-files

# Database (Cloud SQL PostgreSQL)
EBOOK_AGENT_DATABASE_URL=postgresql://ebook_agent:PASSWORD@PRIVATE_IP/ebook_agent

# Optional: Claude AI integration
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: HeyGen video generation
# EBOOK_AGENT_HEYGEN_API_KEY=your-heygen-api-key
